# ─── Backend endpoints ────────────────────────────────
# All Qwen / Redis / OSS / DB credentials live in analytics-brain/.env —
# the frontend never holds secrets. Only NEXT_PUBLIC_ vars belong here.
NEXT_PUBLIC_API_URL=http://localhost:9000
NEXT_PUBLIC_WS_URL=ws://localhost:9000/ws

# ─── App ──────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
